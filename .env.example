PORT=9090

# Runtime environment: development (default) | production | test.
# In production the server refuses to boot unless at least one auth mode below
# is configured. development keeps the zero-config open mode (with a warning).
NODE_ENV=development

# Basic auth (optional — legacy auth path, when both are set Basic credentials
# are accepted on native ingest routes)
AGENT_OBSERVABILITY_USER=
AGENT_OBSERVABILITY_PASS=

# LiveKit-native auth (optional — when both are set, native ingest routes
# accept Bearer JWTs minted by the LiveKit SDK with the same key/secret pair.
# agent-transport >= 0.1.10 uploads via this path; older clients use Basic
# above. Either auth mode on its own is enough.)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Postgres (required)
DATABASE_URL=postgres://user:password@localhost:5432/agent_observability
AUTO_MIGRATE=false

# S3 recording upload (optional — when set, audio recordings are uploaded to S3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PREFIX=recordings

# Alert sweeper placement. 'inline' (default) runs it inside the API process.
# Set 'off' when running the dedicated worker entrypoint (bun src/worker.ts)
# so exactly one sweeper is active.
ALERT_SWEEPER=inline

# Generic job worker placement (Stage 0.4), mirrors ALERT_SWEEPER. 'inline'
# (default) runs the job loop inside the API; set 'off' when the dedicated
# worker (bun src/worker.ts) runs so jobs aren't processed twice.
JOBS_WORKER=inline

# CORS allow-list for the /api/* dashboard endpoints. Comma-separated
# origins. Defaults to "*" (any origin). In production the dashboard is
# served same-origin, so set this only when it runs on a different origin.
# CORS_ALLOWED_ORIGINS=https://obs.example.com,http://localhost:5173

# ── LLM provider (Stage 0.3) ─────────────────────────────────────────────────
# Provider-neutral LLM layer used by the eval/simulation engines. Pick the
# provider; only that provider's key is read. OPENAI_BASE_URL lets the OpenAI
# adapter target Azure OpenAI / OpenRouter / a local server.
LLM_PROVIDER=anthropic            # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Per-role model overrides (empty = provider default:
# claude-opus-4-8 for anthropic, gpt-4.1-mini for openai).
JUDGE_MODEL=
SIMULATOR_MODEL=
GENERATOR_MODEL=

# completeJSON request hardening.
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=1
