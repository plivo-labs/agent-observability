PORT=9090

# Basic auth (optional — legacy auth path, when both are set Basic credentials
# are accepted on native ingest routes)
AGENT_OBSERVABILITY_USER=
AGENT_OBSERVABILITY_PASS=

# LiveKit-native auth (optional — when both are set, native ingest routes
# accept Bearer JWTs minted by the LiveKit SDK with the same key/secret pair.
# agent-transport >= 0.1.10 uploads via this path; older clients use Basic
# above. Either auth mode on its own is enough.)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Postgres (required)
DATABASE_URL=postgres://user:password@localhost:5432/agent_observability
AUTO_MIGRATE=false

# S3 recording upload (optional — when set, audio recordings are uploaded to S3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PREFIX=recordings

# Simulation engine LLM (optional — OpenAI-compatible Chat Completions API).
# When set, Simulate runs real persona↔agent conversations + an LLM judge;
# otherwise it returns clearly-labelled, prompt-derived demo data.
SIM_LLM_API_KEY=
SIM_LLM_BASE_URL=https://api.openai.com/v1
SIM_LLM_MODEL=gpt-4o-mini

# Azure OpenAI for Simulate generation (alternative to SIM_LLM_*; same Azure
# account Truman uses). When endpoint + key are set, Simulate generates real
# persona↔agent conversations via Azure instead of prompt-derived demo.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# Truman caller (optional — real LiveKit/PSTN calls for the Live module).
# When TRUMAN_API_URL + TRUMAN_API_TOKEN are set, Live places REAL calls via
# Truman's API and Truman judges the real call transcript; otherwise Live runs
# the demo/LLM shell. Real dialing additionally requires Truman's caller worker
# running (cd truman && uv run python -m caller.server) + a public tunnel.
TRUMAN_API_URL=
TRUMAN_API_TOKEN=
TRUMAN_JUDGE_MODEL=gpt-4.1-mini
TRUMAN_DEFAULT_VOICE_ID=
