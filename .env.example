PORT=9090

# LiveKit JWT verification (required)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Postgres (required)
DATABASE_URL=postgres://user:password@localhost:5432/agent_observability
AUTO_MIGRATE=true

# S3 recording upload (optional — when set, audio recordings are uploaded to S3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PREFIX=recordings
