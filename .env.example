PORT=9090

# Basic auth (optional — legacy auth path, when both are set Basic credentials
# are accepted on native ingest routes)
AGENT_OBSERVABILITY_USER=
AGENT_OBSERVABILITY_PASS=

# LiveKit-native auth (optional — when both are set, native ingest routes
# accept Bearer JWTs minted by the LiveKit SDK with the same key/secret pair.
# agent-transport >= 0.1.10 uploads via this path; older clients use Basic
# above. Either auth mode on its own is enough.)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Postgres (required)
# Postgres. Required in the default (self-contained) mode; OPTIONAL when SIM_PERSIST=false
# (stateless generator — Plivo / bring-your-own-backend — boots with no database).
DATABASE_URL=postgres://user:password@localhost:5432/agent_observability
AUTO_MIGRATE=false

# S3 recording upload (optional — when set, audio recordings are uploaded to S3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PREFIX=recordings

# Alert sweeper placement. 'inline' (default) runs it inside the API process.
# Set 'off' when running the dedicated worker entrypoint (bun src/worker.ts)
# so exactly one sweeper is active.
ALERT_SWEEPER=inline

# CORS allow-list for the /api/* dashboard endpoints. Comma-separated
# origins. Defaults to "*" (any origin). In production the dashboard is
# served same-origin, so set this only when it runs on a different origin.
# CORS_ALLOWED_ORIGINS=https://obs.example.com,http://localhost:5173

# ── LLM provider (simulation scenario generator) ─────────────────────────────
# Provider-neutral: src/llm/completeJSON dispatches to the adapter named here.
# Set the key for the selected provider only. OPENAI_BASE_URL points the OpenAI
# adapter at Azure OpenAI / OpenRouter / a local server (how Plivo's gpt-5.5-1
# endpoint is wired in). Defaults work for unit tests, which inject a mock LLM.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
# Per-role model overrides (empty = the adapter's built-in default).
JUDGE_MODEL=
SIMULATOR_MODEL=
GENERATOR_MODEL=
# completeJSON request hardening: per-attempt timeout (ms) + retry count.
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=1

# ── Simulation engine ────────────────────────────────────────────────────────
# Capability-gated, NOT all-or-nothing: generation needs only an LLM key (above);
# runs need REDIS_URL + LIVEKIT_SIM_TURN_URL; the SQS consumer additionally needs
# SIM_EVAL_SQS_QUEUE_URL. SIM_EVAL_SQS_QUEUE_URL is the run-dispatch plug-in (Plivo) —
# leave it unset for a generation-only deploy.
# AWS credentials come from the standard AWS provider chain
# (AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY env, shared config, or an instance role)
# — never put them here.
SIM_EVAL_SQS_QUEUE_URL=
REDIS_URL=
# Set true when REDIS_URL points at a Redis Cluster (Plivo prod). The
# SIM_EVAL:{run_uuid}:* hash tags + the worker's 3-key Lua gate require cluster mode
# to co-locate keys; default false = standalone (dev / dockerized E2E).
REDIS_CLUSTER=false
AWS_REGION=us-east-1
# Scenario-generation model (default gpt-5.5-1, matching aiassist).
SIM_EVAL_SCENARIO_GENERATION_MODEL=gpt-5.5-1

# Scenario-library persistence mode (how AO stores generated scenarios):
#   true  (default) — SELF-CONTAINED (OSS): AO writes each scenario to its own Postgres
#                     (ao_simulation_scenarios) and serves the library API. Needs DATABASE_URL.
#   false           — STATELESS (Plivo / bring-your-own-backend): AO streams scenarios but
#                     writes NO database; the host (aiassist) persists them. No DATABASE_URL needed.
# The per-request `?persist=true|false` query param overrides this default.
SIM_PERSIST=true

# ── Run engine (the ported cx-sqs-worker simulation loop) ────────────────────
# Runs are dispatched only via the SQS consumer (bun src/worker.ts), which drains run
# messages produced by aiassist; AO stays stateless on the run path (Redis-only). Needs
# SIM_EVAL_SQS_QUEUE_URL + REDIS_URL + LIVEKIT_SIM_TURN_URL.
# Redis key prefix for the run-scoped keys (FLOW_JSON / SCENARIO_EXPECTED_COUNT /
# RESULTS / the Lua completion counters). Default SIM_EVAL matches aiassist on
# Plivo's shared Redis; override for an OSS deploy with its own Redis.
SIM_REDIS_PREFIX=SIM_EVAL
# Base URL of plivo-cx-livekit. The engine POSTs each turn to
# {LIVEKIT_SIM_TURN_URL}/v1/simulation/session/turn. Required for the run engine.
LIVEKIT_SIM_TURN_URL=
# UserSimulator (simulated caller) LLM model. Falls back to the generation model
# above when unset.
USER_SIMULATOR_MODEL=
# Scenarios one worker process runs concurrently (SQS consumer fan-out).
SIM_WORKER_CONCURRENCY=4
