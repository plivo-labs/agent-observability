      "--accent-purple-border": "277 41% 82%",
      "--warning-bg": "42 64% 91%",
      "--warning-border": "42 64% 82%",
      "--warning-fg": "34 85% 36%",
      "--destructive-bg": "12 71% 94%",
      "--destructive-border": "12 71% 86%",
      "--code-key": "60 7% 5%",
      "--code-string": "42 6% 40%",
      "--code-number": "42 6% 40%",
      "--code-bool": "42 6% 40%",
      "--radius": "0",
      "--radius-sm": "0",
      "--radius-md": "0",
      "--radius-lg": "0",
      "--radius-xl": "0",
      "--radius-2xl": "0",
      "--radius-xs": "0.125rem",
      "--radius-pill": "9999px",
      "--tracking-section": "0.14em",
      "--color-background": "hsl(var(--background))",
      "--color-foreground": "hsl(var(--foreground))",
      "--color-card": "hsl(var(--card))",
      "--color-card-foreground": "hsl(var(--card-foreground))",
      "--color-popover": "hsl(var(--popover))",
      "--color-popover-foreground": "hsl(var(--popover-foreground))",
      "--color-primary": "hsl(var(--primary))",
      "--color-primary-foreground": "hsl(var(--primary-foreground))",
      "--color-secondary": "hsl(var(--secondary))",
      "--color-secondary-foreground": "hsl(var(--secondary-foreground))",
      "--color-muted": "hsl(var(--muted))",
      "--color-muted-foreground": "hsl(var(--muted-foreground))",
      "--color-accent": "hsl(var(--accent))",
      "--color-accent-foreground": "hsl(var(--accent-foreground))",
      "--color-destructive": "hsl(var(--destructive))",
      "--color-destructive-foreground": "hsl(var(--destructive-foreground))",
      "--color-border": "hsl(var(--border))",
      "--color-input": "hsl(var(--input))",
      "--color-ring": "hsl(var(--ring))",
      "--color-chart-1": "hsl(var(--chart-1))",
      "--color-chart-2": "hsl(var(--chart-2))",
      "--color-chart-3": "hsl(var(--chart-3))",
      "--color-chart-4": "hsl(var(--chart-4))",
      "--color-chart-5": "hsl(var(--chart-5))",
      "--color-success": "hsl(var(--success))",
      "--color-success-foreground": "hsl(var(--success-foreground))",
      "--color-success-bg": "hsl(var(--success-bg))",
      "--color-success-border": "hsl(var(--success-border))",
      "--color-success-fg": "hsl(var(--success-fg))",
      "--color-warning": "hsl(var(--warning))",
      "--color-warning-foreground": "hsl(var(--warning-foreground))",
      "--color-warning-bg": "hsl(var(--warning-bg))",
      "--color-warning-border": "hsl(var(--warning-border))",
      "--color-warning-fg": "hsl(var(--warning-fg))",
      "--color-destructive-bg": "hsl(var(--destructive-bg))",
      "--color-destructive-border": "hsl(var(--destructive-border))",
      "--color-info": "hsl(var(--info))",
      "--color-info-foreground": "hsl(var(--info-foreground))",
      "--color-info-bg": "hsl(var(--info-bg))",
      "--color-info-border": "hsl(var(--info-border))",
      "--color-accent-purple": "hsl(var(--accent-purple))",
      "--color-accent-purple-foreground": "hsl(var(--accent-purple-foreground))",
      "--color-accent-purple-bg": "hsl(var(--accent-purple-bg))",
      "--color-accent-purple-border": "hsl(var(--accent-purple-border))",
      "--color-bubble-agent": "hsl(var(--bubble-agent))",
      "--color-bubble-user": "hsl(var(--bubble-user))",
      "--color-tertiary": "hsl(var(--tertiary))",
      "--color-tertiary-foreground": "hsl(var(--tertiary-foreground))",
      "--color-link": "hsl(var(--link))",
      "--color-st1": "hsl(var(--st1))",
      "--color-st2": "hsl(var(--st2))",
      "--color-bg1": "hsl(var(--bg1))",
      "--color-bg2": "hsl(var(--bg2))",
      "--color-bg3": "hsl(var(--bg3))",
      "--color-hv1": "hsl(var(--hv1))",
      "--color-hv2": "hsl(var(--hv2))",
      "--color-hv3": "hsl(var(--hv3))",
      "--font-sans": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
      "--font-display": "var(--font-sans)",
      "--font-mono": "ui-monospace, SFMono-Regular, \"SF Mono\", Menlo, Consolas, \"Liberation Mono\", monospace",
      "--text-h1-600": "700 28px/36px var(--font-sans)",
      "--text-h1-400": "400 28px/36px var(--font-sans)",
      "--text-h2-600": "600 22px/30px var(--font-sans)",
      "--text-h2-400": "400 22px/30px var(--font-sans)",
      "--text-h3-600": "600 18px/26px var(--font-sans)",
      "--text-h3-400": "400 18px/26px var(--font-sans)",
      "--text-h4-600": "600 16px/24px var(--font-sans)",
      "--text-h4-400": "400 16px/24px var(--font-sans)",
      "--text-l-600": "600 15px/22px var(--font-sans)",
      "--text-p-600": "600 14px/20px var(--font-sans)",
      "--text-p-500": "500 14px/20px var(--font-sans)",
      "--text-p-400": "400 14px/20px var(--font-sans)",
      "--text-pi-400": "400 italic 14px/20px var(--font-sans)",
      "--text-s-600": "600 13px/18px var(--font-sans)",
      "--text-s-500": "500 13px/18px var(--font-sans)",
      "--text-s-400": "400 13px/18px var(--font-sans)",
      "--text-xs-600": "600 12px/16px var(--font-sans)",
      "--text-xs-500": "500 12px/16px var(--font-sans)",
      "--text-xs-400": "400 12px/16px var(--font-sans)",
      "--text-xsi-400": "400 italic 12px/16px var(--font-sans)",
      "--text-xxs-600": "600 11px/14px var(--font-sans)",
      "--text-xxs-400": "400 11px/14px var(--font-sans)",
      "--text-xl-700": "700 32px/40px var(--font-sans)",
      "--card-shadow": "0 1px 3px 0 hsl(220 15% 50% / 0.04), 0 1px 2px -1px hsl(220 15% 50% / 0.04)",
      "--mono": "ui-monospace, \"SF Mono\", \"JetBrains Mono\", Menlo, Consolas, monospace"
    },
    ":where(.dark)": {
      "--background": "48 10% 7%",
      "--foreground": "45 35% 93%",
      "--card": "45 9% 10%",
      "--card-foreground": "45 35% 93%",
      "--popover": "45 9% 10%",
      "--popover-foreground": "45 35% 93%",
      "--primary": "45 35% 93%",
      "--primary-foreground": "48 10% 7%",
      "--secondary": "42 14% 78%",
      "--secondary-foreground": "48 10% 7%",
      "--tertiary": "42 8% 53%",
      "--tertiary-foreground": "48 10% 7%",
      "--muted": "45 9% 13%",
      "--muted-foreground": "42 8% 53%",
      "--accent": "9 65% 55%",
      "--accent-foreground": "0 0% 100%",
      "--destructive": "9 65% 55%",
      "--destructive-foreground": "0 0% 98%",
      "--success": "141 35% 48%",
      "--success-foreground": "45 35% 93%",
      "--warning": "34 85% 56%",
      "--warning-foreground": "48 10% 7%",
      "--border": "40 9% 16%",
      "--input": "40 9% 16%",
      "--ring": "45 35% 93%",
      "--link": "217 70% 65%",
      "--chart-1": "217 75% 65%",
      "--chart-2": "267 65% 75%",
      "--chart-3": "141 35% 48%",
      "--chart-4": "34 85% 56%",
      "--chart-5": "9 65% 55%",
      "--st1": "40 9% 16%",
      "--st2": "45 9% 13%",
      "--bg1": "48 10% 7%",
      "--bg2": "45 9% 9%",
      "--bg3": "45 9% 13%",
      "--hv1": "45 9% 12%",
      "--hv2": "45 8% 15%",
      "--hv3": "40 8% 18%",
      "--bubble-agent": "217 40% 16%",
      "--bubble-user": "45 9% 11%",
      "--bubble-customer": "var(--bubble-user)",
      "--success-bg": "141 35% 12%",
      "--success-border": "141 25% 22%",
      "--success-fg": "141 55% 70%",
      "--info": "217 75% 65%",
      "--info-bg": "217 50% 14%",
      "--info-border": "217 35% 26%",
      "--accent-purple": "267 65% 75%",
      "--accent-purple-bg": "267 40% 16%",
      "--accent-purple-border": "267 30% 30%",
      "--warning-bg": "38 50% 12%",
      "--warning-border": "38 35% 24%",
      "--warning-fg": "38 80% 72%",
      "--destructive-bg": "9 50% 14%",
      "--destructive-border": "9 40% 26%",
      "--code-key": "45 35% 93%",
      "--code-string": "42 8% 60%",
      "--code-number": "42 8% 60%",
      "--code-bool": "42 8% 60%",
      "--card-shadow": "0 1px 3px 0 hsl(0 0% 0% / 0.3), 0 1px 2px -1px hsl(0 0% 0% / 0.3)"
    },
    ":where(.obs-metrics)": {
      "display": "grid",
      "grid-template-columns": "repeat(auto-fit, minmax(140px, 1fr))",
      "gap": "12px",
      "margin-top": "16px"
    },
    ":where(.metric-tile)": {
      "min-width": "0",
      "background": "hsl(var(--card))",
      "border": "1px solid hsl(var(--border))",
      "border-radius": "10px",
      "padding": "14px 16px"
    },
    ":where(.metric-tile .hd)": {
      "display": "flex",
      "align-items": "center",
      "gap": "6px",
      "color": "hsl(var(--tertiary))",
      "font-size": "12px",
      "font-weight": "600",
      "line-height": "16px",
      "text-transform": "uppercase",
      "letter-spacing": "0.04em",
      "margin-bottom": "10px"
    },
    ":where(.metric-tile .hd svg)": {
      "color": "hsl(var(--tertiary))"
    },
    ":where(.metric-tile .val)": {
      "color": "hsl(var(--foreground))",
      "font-size": "22px",
      "font-weight": "600",
      "line-height": "30px",
      "letter-spacing": "-0.01em",
      "font-feature-settings": "\"tnum\""
    },
    ":where(.metric-tile .sub)": {
      "color": "hsl(var(--tertiary))",
      "font-size": "12px",
      "font-weight": "400",
      "line-height": "16px",
      "margin-top": "2px"
    },
    ":where(.metric-tile.good .val)": {
      "color": "hsl(var(--success-fg, var(--success)))"
    },
    ":where(.metric-tile.warn)": {
      "border-color": "hsl(var(--warning-border))"
    },
    ":where(.metric-tile.warn .val)": {
      "color": "hsl(var(--warning-fg, var(--warning)))",
      "font-weight": "700"
    },
    ":where(.metric-tile.bad)": {
      "border-color": "hsl(var(--destructive-border))"
    },
    ":where(.metric-tile.bad .val)": {
      "color": "hsl(var(--destructive))",
      "font-weight": "700"
    },
    ":where(.mono)": {
      "font-family": "var(--mono)",
      "font-variant-numeric": "tabular-nums"
    },
    ":where(.muted)": {
      "color": "hsl(var(--muted-foreground))"
    },
    ":where(.tnum)": {
      "font-variant-numeric": "tabular-nums"
    },
    ":where(.metric-tile, .events-card)": {
      "box-shadow": "var(--card-shadow)"
    },
    ":where(.events-card)": {
      "min-width": "0",
      "max-width": "100%",
      "background": "hsl(var(--card))",
      "border": "1px solid hsl(var(--border))",
      "border-radius": "12px",
      "overflow": "hidden"
    },
    ":where(.events-head)": {
      "display": "flex",
      "align-items": "center",
      "justify-content": "space-between",
      "gap": "12px",
      "min-width": "0",
      "padding": "14px 18px",
      "border-bottom": "1px solid hsl(var(--border))"
    },
    ":where(.events-head .title)": {
      "min-width": "0",
      "display": "inline-flex",
      "align-items": "baseline",
      "gap": "10px",
      "font": "var(--text-p-600)",
      "color": "hsl(var(--foreground))"
    },
    ":where(.events-head .title .rng)": {
      "min-width": "0",
      "overflow": "hidden",
      "text-overflow": "ellipsis",
      "white-space": "nowrap",
      "font": "var(--text-xs-400)",
      "color": "hsl(var(--tertiary))",
      "font-family": "var(--mono)",
      "font-weight": "500"
    },
    ":where(.events-head .timemode)": {
      "flex-shrink": "0",
      "display": "inline-flex",
      "align-items": "center",
      "gap": "6px",
      "height": "28px",
      "padding": "0 10px",
      "border": "1px solid hsl(var(--input))",
      "border-radius": "6px",
      "color": "hsl(var(--muted-foreground))",
      "font": "var(--text-xs-500)",
      "background": "hsl(var(--card))",
      "cursor": "pointer"
    },
    ":where(.events-list)": {
      "min-width": "0",
      "padding": "4px 0"
    },
    ":where(.ev-row-wrap)": {
      "border-bottom": "1px solid hsl(var(--border) / 0.6)"
    },
    ":where(.ev-row-wrap:last-child)": {
      "border-bottom": "none"
    },
    ":where(.ev-row)": {
      "display": "grid",
      "grid-template-columns": "22px 78px minmax(0, max-content) minmax(0, 1fr)",
      "gap": "12px",
      "min-width": "0",
      "width": "100%",
      "align-items": "center",
      "padding": "9px 18px",
      "cursor": "pointer",
      "text-align": "left",
      "transition": "background .1s",
      "background": "transparent",
      "border": "0",
      "color": "inherit",
      "font": "inherit"
    },
    ":where(.ev-row.absolute-time)": {
      "grid-template-columns": "22px 96px minmax(0, max-content) minmax(0, 1fr)"
    },
    ":where(.ev-row:hover)": {
      "background": "hsl(var(--bg2))"
    },
    ":where(.ev-row:focus-visible)": {
      "outline": "2px solid hsl(var(--ring) / 0.4)",
      "outline-offset": "-2px"
    },
    ":where(.ev-row .caret)": {
      "color": "hsl(var(--tertiary))",
      "width": "14px",
      "display": "flex",
      "transition": "transform .15s"
    },
    ":where(.ev-detail)": {
      "margin": "0",
      "padding": "10px 18px 14px 52px",
      "font-family": "var(--mono)",
      "font-size": "11.5px",
      "line-height": "1.55",
      "color": "hsl(var(--muted-foreground))",
      "background": "hsl(var(--bg2) / 0.6)",
      "white-space": "pre-wrap",
      "word-break": "break-all",
      "max-height": "360px",
      "overflow": "auto"
    },
    ":where(.ev-row .t)": {
      "min-width": "0",
      "overflow": "hidden",
      "text-overflow": "ellipsis",
      "white-space": "nowrap",
      "font-family": "var(--mono)",
      "font-size": "11.5px",
      "color": "hsl(var(--muted-foreground))",
      "font-feature-settings": "\"tnum\"",
      "text-align": "right"
    },
    ":where(.ev-row .tag)": {
      "min-width": "0",
      "max-width": "13rem",
      "display": "inline-flex",
      "align-items": "center",
      "padding": "2px 8px",
      "height": "20px",
      "border-radius": "4px",
      "font-family": "var(--mono)",
      "font-size": "11px",
      "font-weight": "600",
      "letter-spacing": "0.01em",
      "border": "1px solid transparent",
      "white-space": "nowrap",
      "overflow": "hidden",
      "text-overflow": "ellipsis"
    },
    ":where(.ev-row .tag > span)": {
      "min-width": "0",
      "overflow": "hidden",
      "text-overflow": "ellipsis",
      "white-space": "nowrap"
    },
    ":where(.ev-tag-conv)": {
      "background": "hsl(var(--info-bg))",
      "color": "hsl(var(--info))",
      "border-color": "hsl(var(--info-border))"
    },
    ":where(.ev-tag-speech)": {
      "background": "hsl(var(--warning-bg))",
      "color": "hsl(var(--warning-fg, var(--warning)))",
      "border-color": "hsl(var(--warning-border))"
    },
    ":where(.ev-tag-agent)": {
      "background": "hsl(var(--accent-purple-bg))",
      "color": "hsl(var(--accent-purple))",
      "border-color": "hsl(var(--accent-purple-border))"
    },
    ":where(.ev-tag-user)": {
      "background": "hsl(var(--success-bg))",
      "color": "hsl(var(--success-fg, var(--success)))",
      "border-color": "hsl(var(--success-border))"
    },
    ":where(.ev-row .msg)": {
      "min-width": "0",
      "font": "var(--text-s-400)",
      "color": "hsl(var(--foreground))",
      "overflow": "hidden",
      "text-overflow": "ellipsis",
      "white-space": "nowrap"
    },
    ":where(.ev-row .msg .arrow)": {
      "color": "hsl(var(--tertiary))",
      "margin": "0 4px"
    },
    ":where(.ev-row .msg b)": {
      "font-weight": "600",
      "color": "hsl(var(--foreground))"
    },
    ":where(.ev-row .msg q)": {
      "color": "hsl(var(--muted-foreground))",
      "quotes": "\"\\\"\" \"\\\"\""
    }
  },
  "type": "registry:theme"
}