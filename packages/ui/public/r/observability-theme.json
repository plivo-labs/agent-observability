      "--hv1": "45 22% 92%",
      "--hv2": "45 20% 88%",
      "--hv3": "45 18% 84%",
      "--app-bg": "hsl(var(--bg2))",
      "--bubble-agent": "213 31% 95%",
      "--bubble-user": "47 21% 96%",
      "--bubble-customer": "var(--bubble-user)",
      "--success-bg": "132 24% 91%",
      "--success-border": "132 24% 80%",
      "--success-fg": "141 42% 29%",
      "--info": "217 64% 34%",
