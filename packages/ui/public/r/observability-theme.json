{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "observability-theme",
  "title": "Observability Theme",
  "description": "CSS variables and typography scale for observability components",
  "files": [],
  "cssVars": {
    "theme": {
      "font-sans": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
      "font-mono": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
      "font-size-h1-600": "26px",
      "line-height-h1-600": "32px",
      "font-size-h1-400": "26px",
      "line-height-h1-400": "32px",
      "font-size-h2-600": "22px",
      "line-height-h2-600": "32px",
      "font-size-h2-400": "22px",
      "line-height-h2-400": "32px",
      "font-size-h3-600": "18px",
      "line-height-h3-600": "26px",
      "font-size-h3-400": "18px",
      "line-height-h3-400": "26px",
      "font-size-h4-600": "16px",
      "line-height-h4-600": "24px",
      "font-size-h4-400": "16px",
      "line-height-h4-400": "24px",
      "font-size-p-600": "14px",
      "line-height-p-600": "20px",
      "font-size-p-500": "14px",
      "line-height-p-500": "20px",
      "font-size-p-400": "14px",
      "line-height-p-400": "20px",
      "font-size-s-600": "13px",
      "line-height-s-600": "18px",
      "font-size-s-500": "13px",
      "line-height-s-500": "18px",
      "font-size-s-400": "13px",
      "line-height-s-400": "18px",
      "font-size-xs-600": "12px",
      "line-height-xs-600": "18px",
      "font-size-xs-500": "12px",
      "line-height-xs-500": "18px",
      "font-size-xs-400": "12px",
      "line-height-xs-400": "13px",
      "font-size-xxs-400": "10px",
      "line-height-xxs-400": "13px",
      "font-size-xxs-600": "10px",
      "line-height-xxs-600": "13px",
      "color-st1": "hsl(var(--st1))",
      "color-st2": "hsl(var(--st2))",
      "color-bg1": "hsl(var(--bg1))",
      "color-bg2": "hsl(var(--bg2))",
      "color-bg3": "hsl(var(--bg3))",
      "color-hv1": "hsl(var(--hv1))",
      "color-hv2": "hsl(var(--hv2))",
      "color-hv3": "hsl(var(--hv3))"
    }
  },
  "css": {
    ":where(html)": {
      "--background": "47 21% 96%",
      "--foreground": "60 7% 5%",
      "--card": "0 0% 100%",
      "--card-foreground": "60 7% 5%",
