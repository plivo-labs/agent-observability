      "--secondary": "47 11% 20%",
      "--secondary-foreground": "47 21% 96%",
      "--tertiary": "42 6% 40%",
      "--tertiary-foreground": "47 21% 96%",
      "--muted": "45 25% 91%",
      "--muted-foreground": "42 6% 40%",
      "--accent": "9 78% 45%",
      "--accent-foreground": "0 0% 100%",
      "--destructive": "9 78% 45%",
