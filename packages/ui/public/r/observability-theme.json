    ":where(.obs-metrics)": {
      "display": "grid",
      "grid-template-columns": "repeat(auto-fit, minmax(140px, 1fr))",
      "gap": "12px",
      "margin-top": "16px"
    },
    ":where(.metric-tile)": {
      "min-width": "0",
      "background": "var(--card)",
      "border": "1px solid var(--border)",
      "border-radius": "0",
      "padding": "14px 16px"
    },
    ":where(.metric-tile .hd)": {
      "display": "flex",
      "align-items": "center",
      "gap": "6px",
      "color": "var(--tertiary)",
      "font-size": "10px",
      "font-weight": "600",
      "line-height": "14px",
      "text-transform": "uppercase",
      "letter-spacing": "0.18em",
      "margin-bottom": "10px"
    },
    ":where(.metric-tile .hd svg)": {
      "color": "var(--tertiary)"
    },
    ":where(.metric-tile .val)": {
      "color": "var(--foreground)",
      "font-size": "22px",
      "font-weight": "600",
      "line-height": "30px",
      "letter-spacing": "-0.01em",
      "font-feature-settings": "\"tnum\""
    },
    ":where(.metric-tile .sub)": {
      "color": "var(--tertiary)",
      "font-size": "12px",
      "font-weight": "400",
      "line-height": "16px",
      "margin-top": "2px"
    },
    ":where(.metric-tile.good .val)": {
      "color": "var(--success-fg)"
    },
    ":where(.metric-tile.warn)": {
      "border-color": "var(--warning-border)"
    },
    ":where(.metric-tile.warn .val)": {
      "color": "var(--warning-fg)",
      "font-weight": "700"
    },
    ":where(.metric-tile.bad)": {
      "border-color": "var(--destructive-border)"
    },
    ":where(.metric-tile.bad .val)": {
      "color": "var(--destructive)",
      "font-weight": "700"
    },
    ":where(.mono)": {
      "font-family": "var(--mono)",
      "font-variant-numeric": "tabular-nums"
    },
    ":where(.muted)": {
      "color": "var(--muted-foreground)"
    },
    ":where(.tnum)": {
      "font-variant-numeric": "tabular-nums"
    },
    ":where(.metric-tile, .events-card)": {
      "box-shadow": "var(--card-shadow)"
    },
    ":where(.events-card)": {
      "min-width": "0",
      "max-width": "100%",
      "background": "var(--card)",
      "border": "1px solid var(--border)",
      "border-radius": "12px",
      "overflow": "hidden"
    },
    ":where(.events-head)": {
      "display": "flex",
      "align-items": "center",
      "justify-content": "space-between",
      "gap": "12px",
      "min-width": "0",
      "padding": "14px 18px",
      "border-bottom": "1px solid var(--border)"
    },
    ":where(.events-head .title)": {
      "min-width": "0",
      "display": "inline-flex",
      "align-items": "baseline",
      "gap": "10px",
      "font": "var(--text-p-600)",
      "color": "var(--foreground)"
    },
    ":where(.events-head .title .rng)": {
      "min-width": "0",
      "overflow": "hidden",
      "text-overflow": "ellipsis",
      "white-space": "nowrap",
      "font": "var(--text-xs-400)",
      "color": "var(--tertiary)",
      "font-family": "var(--mono)",
      "font-weight": "500"
    },
    ":where(.events-head .timemode)": {
      "flex-shrink": "0",
      "display": "inline-flex",
      "align-items": "center",
      "gap": "6px",
      "height": "28px",
      "padding": "0 10px",
      "border": "1px solid var(--input)",
      "border-radius": "6px",
      "color": "var(--muted-foreground)",
      "font": "var(--text-xs-500)",
      "background": "var(--card)",
      "cursor": "pointer"
    },
    ":where(.events-list)": {
      "min-width": "0",
      "padding": "4px 0"
    },
    ":where(.ev-row-wrap)": {
      "border-bottom": "1px solid color-mix(in oklab, var(--border) 60%, transparent)"
    },
    ":where(.ev-row-wrap:last-child)": {
      "border-bottom": "none"
    },
    ":where(.ev-row)": {
      "display": "grid",
      "grid-template-columns": "22px 78px minmax(0, max-content) minmax(0, 1fr)",
      "gap": "12px",
      "min-width": "0",
      "width": "100%",
      "align-items": "center",
      "padding": "9px 18px",
      "cursor": "pointer",
      "text-align": "left",
      "transition": "background .1s",
      "background": "transparent",
      "border": "0",
      "color": "inherit",
      "font": "inherit"
    },
    ":where(.ev-row.absolute-time)": {
      "grid-template-columns": "22px 96px minmax(0, max-content) minmax(0, 1fr)"
    },
    ":where(.ev-row:hover)": {
      "background": "var(--bg2)"
    },
    ":where(.ev-row:focus-visible)": {
      "outline": "2px solid color-mix(in oklab, var(--ring) 40%, transparent)",
      "outline-offset": "-2px"
    },
    ":where(.ev-row .caret)": {
      "color": "var(--tertiary)",
      "width": "14px",
      "display": "flex",
      "transition": "transform .15s"
    },
    ":where(.ev-detail)": {
      "margin": "0",
      "padding": "10px 18px 14px 52px",
      "font-family": "var(--mono)",
      "font-size": "11.5px",
      "line-height": "1.55",
      "color": "var(--muted-foreground)",
      "background": "color-mix(in oklab, var(--bg2) 60%, transparent)",
      "white-space": "pre-wrap",
      "word-break": "break-all",
      "max-height": "360px",
      "overflow": "auto"
    },
    ":where(.ev-row .t)": {
      "min-width": "0",
      "overflow": "hidden",
      "text-overflow": "ellipsis",
      "white-space": "nowrap",
      "font-family": "var(--mono)",
      "font-size": "11.5px",
      "color": "var(--muted-foreground)",
      "font-feature-settings": "\"tnum\"",
      "text-align": "right"
    },
    ":where(.ev-row .tag)": {
      "min-width": "0",
      "max-width": "13rem",
      "display": "inline-flex",
      "align-items": "center",
      "padding": "2px 8px",
      "height": "20px",
      "border-radius": "4px",
      "font-family": "var(--mono)",
      "font-size": "11px",
      "font-weight": "600",
      "letter-spacing": "0.01em",
      "border": "1px solid transparent",
      "white-space": "nowrap",
      "overflow": "hidden",
      "text-overflow": "ellipsis"
    },
    ":where(.ev-row .tag > span)": {
      "min-width": "0",
      "overflow": "hidden",
      "text-overflow": "ellipsis",
      "white-space": "nowrap"
    },
    ":where(.ev-tag-conv)": {
      "background": "var(--info-bg)",
      "color": "var(--info)",
      "border-color": "var(--info-border)"
    },
    ":where(.ev-tag-speech)": {
      "background": "var(--warning-bg)",
      "color": "var(--warning-fg)",
      "border-color": "var(--warning-border)"
    },
    ":where(.ev-tag-agent)": {
      "background": "var(--accent-purple-bg)",
      "color": "var(--accent-purple)",
      "border-color": "var(--accent-purple-border)"
    },
    ":where(.ev-tag-user)": {
      "background": "var(--success-bg)",
      "color": "var(--success-fg)",
      "border-color": "var(--success-border)"
    },
    ":where(.ev-row .msg)": {
      "min-width": "0",
      "font": "var(--text-s-400)",
      "color": "var(--foreground)",
      "overflow": "hidden",
      "text-overflow": "ellipsis",
      "white-space": "nowrap"
    },
    ":where(.ev-row .msg .arrow)": {
      "color": "var(--tertiary)",
      "margin": "0 4px"
    },
    ":where(.ev-row .msg b)": {
      "font-weight": "600",
      "color": "var(--foreground)"
    },
    ":where(.ev-row .msg q)": {
      "color": "var(--muted-foreground)",
      "quotes": "\"\\\"\" \"\\\"\""
    }
  },
  "type": "registry:theme"
}