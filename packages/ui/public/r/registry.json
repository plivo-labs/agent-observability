          "bg1": "210 20% 97%",
          "bg2": "210 17% 98%",
          "bg3": "240 5% 96%",
          "hv1": "213 32% 95%",
          "hv2": "220 9% 93%",
          "hv3": "220 7% 91%"
        },
        "dark": {
          "st1": "210 5% 16%",
          "st2": "220 4% 15%"
        }
      },
      "files": []
    },
