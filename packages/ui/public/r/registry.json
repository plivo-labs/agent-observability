          "line-height-p-500": "20px",
          "font-size-p-400": "14px",
          "line-height-p-400": "20px",
          "font-size-s-600": "13px",
          "line-height-s-600": "18px",
          "font-size-s-500": "13px",
          "line-height-s-500": "18px",
          "font-size-s-400": "13px",
          "line-height-s-400": "18px",
          "font-size-xs-600": "12px",
          "line-height-xs-600": "18px",
          "font-size-xs-500": "12px",
          "line-height-xs-500": "18px",
          "font-size-xs-400": "12px",
          "line-height-xs-400": "13px",
          "font-size-xxs-400": "10px",
          "line-height-xxs-400": "13px",
          "font-size-xxs-600": "10px",
          "line-height-xxs-600": "13px",
          "color-st1": "hsl(var(--st1))",
          "color-st2": "hsl(var(--st2))",
          "color-bg1": "hsl(var(--bg1))",
          "color-bg2": "hsl(var(--bg2))",
          "color-bg3": "hsl(var(--bg3))",
          "color-hv1": "hsl(var(--hv1))",
          "color-hv2": "hsl(var(--hv2))",
          "color-hv3": "hsl(var(--hv3))"
