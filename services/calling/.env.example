# ── truman-calling (vendored live-caller) env template ──
# Copy to .env and fill in. This file also anchors settings._find_project_root()
# to services/calling/, so the vendored code never reads ~/truman's .env.

# ── Database — AO's calling has its OWN database, isolated from Truman's ──
# `ao_calling` is a dedicated DB on the same Postgres server (host :5532) as
# Truman's `truman` DB, but a SEPARATE database — so AO's runs never appear in
# Truman and vice-versa. Create it once: `CREATE DATABASE ao_calling OWNER truman;`
# then `bun run caller:migrate`. psycopg3 scheme. (Use `.../truman` instead only
# if you deliberately want to share Truman's data.)
DATABASE_URL=postgresql+psycopg://truman:truman@localhost:5532/ao_calling

# ── Redis (Streams place-call queue + run/audio/takeover pubsub) ──
# Matches docker-compose.yml (Redis 7 on host :6479). DB index /1 keeps the
# place_call queue + pubsub channels isolated from Truman's /0.
REDIS_URL=redis://localhost:6479/1

# ── Auth — MUST equal AO's TRUMAN_API_TOKEN (Bearer the AO backend sends) ──
TRUMAN_API_TOKEN=

# ── Plivo (outbound PSTN dial + recording download) ──
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=
TARGET_NUMBER=

# ── Public tunnels (Plivo must reach these) — HTTPS→:9081, WSS→:9766 ──
PUBLIC_BASE_URL=
PUBLIC_WS_BASE_URL=

# ── Caller media server ports ──
HTTP_HOST=0.0.0.0
HTTP_PORT=9081
AUDIO_STREAM_PORT=9766

# ── Deepgram STT (self-hosted; DEEPGRAM_BASE_URL is the private VPN host) ──
DEEPGRAM_BASE_URL=
DEEPGRAM_API_KEY=self-hosted
DEEPGRAM_MODEL=nova-2-phonecall

# ── ElevenLabs TTS ──
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_BASE_URL=wss://api.elevenlabs.io/v1

# ── Azure OpenAI (persona LLM + judge LLM) ──
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_PERSONA_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_JUDGE_DEPLOYMENT=gpt-4.1-mini

# ── Local data dirs (resolved against services/calling/) ──
RECORDINGS_DIR=./data/recordings
TRANSCRIPTS_DIR=./data/transcripts
EVALS_DIR=./data/evals

LOG_LEVEL=INFO
